# ==========================
# GROQ
# ==========================
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ==========================
# TAVILY
# ==========================
TAVILY_API_KEY=your_tavily_api_key

# ==========================
# FRONTEND
# ==========================
VITE_API_URL=http://localhost:8000

# ==========================
# BRANCH MERGE (BACKEND ONLY)
# ==========================
# Disabled by default. Never commit the plaintext administrative token or its
# production SHA-256 hash. The plaintext token must never use a VITE_* setting.
BRANCH_MERGE_ENABLED=false
BRANCH_MERGE_TOKEN_SHA256=
BRANCH_MERGE_ALLOWED_ORIGINS=
BRANCH_MERGE_MAX_BODY_BYTES=1048576
BRANCH_MERGE_RATE_PER_MINUTE=5
BRANCH_MERGE_RATE_PER_HOUR=20

# ==========================
# DATABASE PERSISTENCE
# ==========================
# DATABASE_URL blank keeps the existing local SQLite database.
# Render PostgreSQL commonly supplies a postgres:// or postgresql:// URL.
# Never commit a production database URL because it contains credentials.
DATABASE_URL=
SQLITE_DB_PATH=
DATABASE_REQUIRE_PERSISTENCE=false
DATABASE_POOL_SIZE=5
DATABASE_CONNECT_TIMEOUT=10

# DOCUMENT OBJECT STORAGE
# Local is suitable for development only.
# Production should use r2 with persistence required.
DOCUMENT_STORAGE_BACKEND=local
DOCUMENT_STORAGE_REQUIRE_PERSISTENCE=false
DOCUMENT_STORAGE_LOCAL_ROOT=

# Cloudflare R2 / S3-compatible private storage.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_REGION=auto

# RAG persistence
# Local development defaults to Chroma.
# PostgreSQL defaults to pgvector.
# RAG_BACKEND=chroma
# RAG_REQUIRE_PERSISTENCE=false
# RAG_EMBEDDING_DIMENSION=384
# RAG_COLLECTION_NAME=pdf_documents
# VECTOR_DB_DIR=storage/vector_db
