# ==========================
# GROQ
# ==========================
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# ==========================
# TAVILY
# ==========================
TAVILY_API_KEY=your_tavily_api_key

# ==========================
# FRONTEND
# ==========================
VITE_API_URL=http://localhost:8000

# ==========================
# BRANCH MERGE (BACKEND ONLY)
# ==========================
# Disabled by default. Never commit the plaintext administrative token or its
# production SHA-256 hash. The plaintext token must never use a VITE_* setting.
BRANCH_MERGE_ENABLED=false
BRANCH_MERGE_TOKEN_SHA256=
BRANCH_MERGE_ALLOWED_ORIGINS=
BRANCH_MERGE_MAX_BODY_BYTES=1048576
BRANCH_MERGE_RATE_PER_MINUTE=5
BRANCH_MERGE_RATE_PER_HOUR=20
